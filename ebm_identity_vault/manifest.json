{
  "manifest_version": 3,
  "name": "EBM Identity Vault",
  "version": "1.0",
  "description": "Offline Secure Zero-Trust Key Storage for EBM Super Admin.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://ebfic.store/*", 
        "https://*.ebfic.store/*",
        "http://localhost:*/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "host_permissions": [
    "http://localhost/*",
    "https://ebfic.store/*"
  ]
}
